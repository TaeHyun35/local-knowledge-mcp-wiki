{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MCP Tool Output Contract",
  "type": "object",
  "required": ["content"],
  "properties": {
    "content": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "text"],
        "properties": {
          "type": { "const": "text" },
          "text": { "type": "string" }
        }
      }
    }
  }
}
